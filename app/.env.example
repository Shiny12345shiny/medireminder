# API Configuration
API_BASE_URL=http://10.25.11.20:5000
SOCKET_URL=http://10.25.11.20:5001

# Replace 192.168.1.100 with your local machine's IP address
# To find your IP:
# - Windows: ipconfig (look for IPv4 Address)
# - Mac/Linux: ifconfig or ip addr (look for inet)

# App Configuration
APP_NAME=Smart Medicine Reminder
APP_VERSION=1.0.0

# Google Maps API Key (for nearby doctors feature)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Expo Project ID (from app.json)
EXPO_PROJECT_ID=your-project-id-here

# Environment
NODE_ENV=development

# Feature Flags
ENABLE_NOTIFICATIONS=true
ENABLE_LOCATION=true
ENABLE_VIDEO_CALLS=true
ENABLE_ANALYTICS=false

# Notification Settings
NOTIFICATION_SOUND=default
VIBRATION_ENABLED=true

# Cache Settings
CACHE_ENABLED=true
CACHE_DURATION=3600000

# Debugging
DEBUG_MODE=true
LOG_LEVEL=info